@model List<CodeAcademyEvents.BLL.DTOs.EventDto>
@{
    ViewData["Title"] = "Tədbirlər";
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <h2 class="mb-0">Tədbirlər</h2>
    @if (User.IsInRole("Admin"))
    {
        <a asp-controller="Events" asp-action="Create" class="btn btn-primary">+ Yeni tədbir</a>
    }
</div>

@if (Model == null || !Model.Any())
{
    <div class="card p-5 text-center text-muted">
        Hələ ki, heç bir tədbir yaradılmayıb.
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var ev in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card event-card h-100">
                    <div class="card-body d-flex flex-column">
                        <span class="event-date-badge align-self-start">@ev.Date.ToString("dd.MM.yyyy HH:mm")</span>
                        <h5 class="card-title">@ev.Title</h5>
                        <p class="card-meta mb-1">@ev.LocationName</p>
                        <p class="card-meta mb-3">@ev.EventTypeName &middot; @ev.OrganizerName</p>
                        <div class="mt-auto d-flex gap-2">
                            <a asp-controller="Events" asp-action="Details" asp-route-id="@ev.Id" class="btn btn-sm btn-outline-primary flex-fill">Ətraflı</a>
                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-controller="Events" asp-action="Edit" asp-route-id="@ev.Id" class="btn btn-sm btn-outline-secondary flex-fill">Redaktə</a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
