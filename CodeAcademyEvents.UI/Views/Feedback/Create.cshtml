@model CodeAcademyEvents.UI.Models.FeedbackFormViewModel
@{
    ViewData["Title"] = "Rəy bildir";
}

<div class="card p-4" style="max-width: 560px;">
    <h2 class="mb-3">Tədbir haqqında rəyiniz</h2>

    <form asp-controller="Feedback" asp-action="Create" method="post">
        <input type="hidden" asp-for="EventId" />
        <input type="hidden" asp-for="PersonId" />

        <div class="mb-3">
            <label class="form-label">Reytinq (1–5)</label>
            <select asp-for="Rating" class="form-select">
                <option value="">Seçin...</option>
                <option value="5">5 — Əla</option>
                <option value="4">4 — Yaxşı</option>
                <option value="3">3 — Normal</option>
                <option value="2">2 — Zəif</option>
                <option value="1">1 — Pis</option>
            </select>
            <span asp-validation-for="Rating" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label class="form-label">Şərh (istəyə bağlı)</label>
            <textarea asp-for="Comment" class="form-control" rows="4" placeholder="Tədbir haqqında fikirlərinizi yazın..."></textarea>
            <span asp-validation-for="Comment" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-primary">Göndər</button>
        <a asp-controller="Events" asp-action="Details" asp-route-id="@Model.EventId" class="btn btn-outline-secondary">Ləğv et</a>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
